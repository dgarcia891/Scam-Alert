{
  "name": "scam-alert-extension",
  "version": "1.0.6",
  "description": "Real-time scam and phishing protection Chrome extension",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "build": "node build/build.js",
    "deploy": "npm run build && node build/sync-nas.js",
    "release": "node scripts/release.js",
    "prepare": "husky"
  },
  "keywords": [
    "chrome-extension",
    "security",
    "phishing",
    "scam-protection"
  ],
  "author": "David Garcia",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/chrome": "^0.0.256",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "extensionsToTreatAsEsm": [],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ]
  }
}