{
  "name": "scam-alert-extension",
  "version": "1.0.83",
  "description": "Real-time scam and phishing protection Chrome extension",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:unit": "npm test",
    "build": "vite build && VITE_ENTRY=src/content/content.js VITE_OUT=content vite build --config vite.content.config.js && VITE_ENTRY=src/content/email-scanner.js VITE_OUT=emailScanner vite build --config vite.content.config.js && cp src/content/content.css dist/assets/content.css",
    "deploy": "npm run build && node build/sync-nas.js",
    "release": "node scripts/release.js",
    "prepare": "husky",
    "build:legacy": "node scripts/build.cjs",
    "release:legacy": "node scripts/release.cjs",
    "test:unit:legacy": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --passWithNoTests",
    "scan": "node scripts/security_scan.cjs",
    "drift": "node scripts/drift_check.cjs"
  },
  "keywords": [
    "chrome-extension",
    "security",
    "phishing",
    "scam-protection"
  ],
  "author": "David Garcia",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/chrome": "^0.0.256",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "jest-chrome": "^0.8.0",
    "eslint": "^8.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3"
  }
}