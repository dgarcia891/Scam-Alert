{
  "name": "hydra-guard-extension",
  "version": "1.0.201",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && VITE_ENTRY=src/content/content.js VITE_OUT=content vite build --config vite.content.config.js && VITE_ENTRY=src/content/email-scanner.js VITE_OUT=emailScanner vite build --config vite.content.config.js && cp src/content/content.css dist/assets/content.css",
    "deploy": "npm run build && node build/sync-nas.js",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.256",
    "@vitejs/plugin-react": "^5.1.2",
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
